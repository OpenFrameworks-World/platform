{
  "@context": {
    "ofw": "https://openframeworks.world/ontology#",
    "schema": "https://schema.org/",
    "id": "@id",
    "type": "@type",
    "Framework": "ofw:Framework",
    "FrameworkFamily": "ofw:FrameworkFamily",
    "FrameworkCard": "ofw:FrameworkCard",
    "Capability": "ofw:Capability",
    "Benchmark": "ofw:Benchmark",
    "Score": "ofw:Score",
    "Evidence": "ofw:Evidence",
    "Policy": "ofw:Policy",
    "Decision": "ofw:Decision",
    "LifecycleState": "ofw:LifecycleState",
    "Artifact": "ofw:Artifact",
    "Blueprint": "ofw:Blueprint",
    "Publisher": "schema:Organization",
    "Maintainer": "schema:Person",
    "name": "schema:name",
    "description": "schema:description",
    "version": "schema:version",
    "license": "schema:license",
    "url": "schema:url",
    "sameAs": "schema:sameAs",
    "dateCreated": "schema:dateCreated",
    "dateModified": "schema:dateModified",
    "domain": "ofw:domain",
    "category": "schema:category",
    "status": "ofw:status",
    "maturity": "ofw:maturity",
    "risk": "ofw:risk",
    "confidence": "ofw:confidence",
    "overallScore": "ofw:overallScore",
    "riskScore": "ofw:riskScore",
    "confidenceScore": "ofw:confidenceScore",
    "recommendation": "ofw:recommendation",
    "dependsOn": { "@id": "ofw:dependsOn", "@type": "@id" },
    "implements": { "@id": "ofw:implements", "@type": "@id" },
    "extends": { "@id": "ofw:extends", "@type": "@id" },
    "competesWith": { "@id": "ofw:competesWith", "@type": "@id" },
    "complements": { "@id": "ofw:complements", "@type": "@id" },
    "governedBy": { "@id": "ofw:governedBy", "@type": "@id" },
    "validatedBy": { "@id": "ofw:validatedBy", "@type": "@id" },
    "belongsTo": { "@id": "ofw:belongsTo", "@type": "@id" },
    "evidence": { "@id": "ofw:evidence", "@type": "@id" }
  }
}
